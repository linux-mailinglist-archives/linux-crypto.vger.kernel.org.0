-	gfp_t gfp;
-	bool diff_dst;
-	int ret;
-
-	if (IS_DECRYPT(rctx->flags))
-		cryptlen = rctx->cryptlen + ctx->authsize;
-	else
-		cryptlen = rctx->cryptlen;
-	totallen = cryptlen + req->assoclen;
