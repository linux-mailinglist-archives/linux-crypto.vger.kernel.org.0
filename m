-	diff_dst = (req->src != req->dst) ? true : false;
-
-	if (diff_dst)
-		rctx->src_nents = sg_nents_for_len(req->src, totallen) + 1;
-	else
-		rctx->src_nents = sg_nents_for_len(req->src, totallen) + 2;
