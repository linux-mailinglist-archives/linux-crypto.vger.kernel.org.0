+static int spacc_set_auxinfo(struct spacc_device *spacc, int jobid,
+			     u32 direction, u32 bitsize)
+{
+	int ret = 0;
+	struct spacc_job *job;
+
+	if (jobid < 0 || jobid >= SPACC_MAX_JOBS)
+		return -EINVAL;
+
+	job = &spacc->job[jobid];
+	if (!job)
+		ret = -EINVAL;
+	else {
+		job->auxinfo_dir = direction;
+		job->auxinfo_bit_align = bitsize;
+	}
+
+	return ret;
+}
