-static unsigned int qce_be32_to_cpu_array(u32 *dst, const u8 *src, unsigned int len)
-{
-	u32 *d = dst;
-	const u8 *s = src;
-	unsigned int n;
-
-	n = len / sizeof(u32);
-	for (; n > 0; n--) {
-		*d = be32_to_cpup((const __be32 *)s);
-		s += sizeof(u32);
-		d++;
-	}
-	return DIV_ROUND_UP(len, sizeof(u32));
-}
